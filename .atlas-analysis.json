  "keyFeatures": [
    "Per-node formatting with fonts, backgrounds, sizes, and effects",
    "Node selection, resizing, positioning, and dragging",
    "Database DBTree for automatic hierarchy from datasets",
    "Virtual mode with on-demand node creation",
    "Links and connections between nodes",
    "Zoom, scroll, and print preview",
    "Custom node shapes including flowchart, UML, and electric symbols",
    "Drag and drop with hot-tracking",
    "Import and export capabilities",
    "Cross-box styles and checkbox/radiogroup selection",
    "Tree diagram designer and node editor",
    "Animation support"
  ],
  "publicApiSurface": [
    "TTree - Main tree control component",
    "TTreeNodeShape - Individual tree node with properties and events",
    "TTreeConnection - Connection line between nodes",
    "TDBTree - Database-aware tree component",
    "TTreeExplorerAlignChild - Windows Explorer style layout",
    "TFlowChartShape - Flowchart shapes (Decision, Process, Terminal, etc.)",
    "TUMLShape - UML diagram shapes (Class, Interface, Actor, etc.)",
    "TElectricShape - Electronic circuit symbols",
    "TTreeEditor - Visual tree designer component",
    "TTreeAnimate - Animation effects for nodes",
    "TTreeNavigator - Navigation control for trees",
    "TGridShape - Grid layout shape",
    "Tree.Add() - Add root or child nodes",
    "Node.AddChild() - Add child node",
    "Node.AddBrother() - Add sibling node",
    "Tree.Roots - Collection of root nodes",
    "Tree.Selected - Collection of selected nodes",
    "Node.Expanded - Expand/collapse children",
    "GlobalFormat.ChildManager - Control node layout",
    "Import/Export - Various formats (XML, HTML, JSON, XLS)"
  ]
}
